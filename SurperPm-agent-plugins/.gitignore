# Benchmark runs contain local paths, provider streams, debug logs, and isolated
# Claude homes. Keep only the scaffold docs in git unless a run is explicitly
# curated and redacted for publication.
benchmark/runs/*
!benchmark/runs/
!benchmark/runs/README.md

# Benchmark target repositories are cloned outside this repo by default, but keep
# local mirrors/caches out of git if someone points scripts inside the plugin repo.
benchmark-targets/
*.benchmark_refresh/
*.bak.*/

# Runtime cache
.marketplace-cache/

